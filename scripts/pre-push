#!/usr/bin/env bash
# Pre-push gate.
#
# JS tests (npm run test:js) run on EVERY push — they're fast, and they can break
# from a sibling-repo shared-runtime change this push never touched (the
# @newspack-nodes/* alias resolves to the nodes source), which a file-type-scoped
# gate misses on a PHP-only or docs-only push.
#
# Everything else is smart-scoped by file type touched in the push range:
#
#   PHP changed  → npm run lint:php  + deploy + coverage suite + per-class 90% gate
#   JS changed   → npm run lint:js   + npm run build
#   SCSS changed → npm run lint:scss + npm run build
#
# Skips the SCOPED gates when the push is only docs / CHANGELOG / config-only
# tweaks (the JS tests still run). Skip the whole gate with `git push
# --no-verify` when you know it's fine (in-flight WIP branches, etc.).
#
# Wired via composer.json `extra.hooks.pre-push`; cghooks installs to
# .git/hooks/pre-push on `composer install`.

set -euo pipefail

HOST=$(hostname -s)
readonly HOST
# --- Per-plugin config — the ONLY part that differs between the aligned hooks. -
# This plugin runs from /services on ${HOST}-pyrobase1-1: the deploy installs a
# release zip and runs PHPUnit straight from the /services source mount (never
# /usr/src), and run-coverage.sh writes to ${PLUGIN_SLUG}-coverage/.
readonly PLUGIN_SLUG="newspack-intelligence"
readonly DEPLOY_SCRIPT="/services/pyrobase/setup/${PLUGIN_SLUG}.sh"
readonly CONTAINER="${HOST}-pyrobase1-1"
readonly TEST_DIR_IN_CONTAINER="/services/pyrobase/sources/${PLUGIN_SLUG}/tests"
readonly COVERAGE_DIR="${PLUGIN_SLUG}-coverage"

red()    { printf '\033[31m%s\033[0m' "$*"; }
green()  { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }
dim()    { printf '\033[2m%s\033[0m' "$*"; }

step() { printf '%s %s\n' "$(yellow '→')" "$*" >&2; }
ok()   { printf '%s %s\n' "$(green '✓')" "$*" >&2; }
fail() { printf '%s %s\n' "$(red   '✗')" "$*" >&2; exit 1; }

# git's native pre-push protocol delivers one "<local_ref> <local_sha>
# <remote_ref> <remote_sha>" line per pushed ref on stdin. Find the diff
# range vs what the remote already has.
range=""
# shellcheck disable=SC2034 # git's stdin protocol: 4 fields, 2 unused.
while read -r local_ref local_sha remote_ref remote_sha; do
	[[ -z "${local_sha:-}" ]] && continue
	if [[ "$local_sha" =~ ^0+$ ]]; then
		continue  # branch delete — nothing to gate
	fi
	if [[ "$remote_sha" =~ ^0+$ ]]; then
		# New branch — compare against main/trunk merge-base.
		base="$(git merge-base "$local_sha" origin/main 2>/dev/null \
		     || git merge-base "$local_sha" origin/trunk 2>/dev/null \
		     || git merge-base "$local_sha" origin/HEAD 2>/dev/null \
		     || echo "${local_sha}~10")"
		range="${base}..${local_sha}"
	else
		range="${remote_sha}..${local_sha}"
	fi
	break  # scope to the first ref-update line; multi-ref pushes are rare
done

if [[ -z "$range" ]]; then
	step "$(dim 'nothing on stdin — skipping')"
	exit 0
fi

step "checking $(dim "$range")"

# JS tests run WITH COVERAGE on every push — they're fast, and a sibling
# shared-runtime change this push never touched can still break them (the
# @newspack-nodes/* alias resolves to the nodes source), which a file-type-scoped
# gate would miss. The per-file JS gate then fails the push if any src file
# dropped below 90% (coverage-gate-js.mjs skips cleanly for a plugin with no JS).
step "test:js (with coverage)"
npm run test:js:coverage --silent || fail "test:js failed — fix or push --no-verify"
ok "test:js clean"

jsgate="$(git rev-parse --show-toplevel)/scripts/coverage-gate-js.mjs"
jssummary="$(git rev-parse --show-toplevel)/coverage/coverage-summary.json"
if [[ -f "$jsgate" ]] && command -v node >/dev/null 2>&1; then
	step "JS coverage gate (every src file ≥ 90%)"
	node "$jsgate" "$jssummary" --threshold 90 >&2 \
		|| fail "JS coverage gate failed — a src file is below 90% (see above)"
	ok "JS coverage gate passed"
fi

# Classify the diff by file type. Exclude generated / vendored paths.
changed="$(git diff --name-only "$range" 2>/dev/null || true)"
php_changed="$(echo  "$changed" | grep -E '\.php$'           | grep -v -E '^(vendor/|release/)'          || true)"
js_changed="$(echo   "$changed" | grep -E '\.(js|jsx|tsx)$'  | grep -v -E '^(node_modules/|build/|release/)' || true)"
scss_changed="$(echo "$changed" | grep -E '\.scss$'          | grep -v -E '^(node_modules/|build/|release/)' || true)"

if [[ -z "$php_changed" && -z "$js_changed" && -z "$scss_changed" ]]; then
	step "$(dim 'no PHP/JS/SCSS in range — skipping')"
	exit 0
fi

# --- Lint pass — only run the linters for file types that actually changed. -
if [[ -n "$php_changed" ]]; then
	step "lint:php ($(echo "$php_changed" | wc -l | tr -d ' ') file(s) changed)"
	npm run lint:php --silent || fail "lint:php failed — fix or push --no-verify"
	ok "lint:php clean"
	# phpstan runs in pre-commit (lint-staged *.php) where the feedback
	# loop is tightest. Doubling it here would re-pay the analysis cost
	# on every push for no extra signal.
fi
if [[ -n "$js_changed" ]]; then
	step "lint:js ($(echo "$js_changed" | wc -l | tr -d ' ') file(s) changed)"
	npm run lint:js --silent || fail "lint:js failed — fix or push --no-verify"
	ok "lint:js clean"
fi
if [[ -n "$scss_changed" ]]; then
	step "lint:scss ($(echo "$scss_changed" | wc -l | tr -d ' ') file(s) changed)"
	npm run lint:scss --silent || fail "lint:scss failed — fix or push --no-verify"
	ok "lint:scss clean"
fi

# --- Build only when frontend changed (release-zip needs current build/). ---
if [[ -n "$js_changed" || -n "$scss_changed" ]]; then
	step "npm run build (frontend changed)"
	npm run build >/dev/null 2>&1 || fail "npm run build failed"
	ok "build clean"
fi

# --- PHP tests run WITH COVERAGE in the docker container when available. ----
# run-coverage.sh runs BOTH phpunit suites (main + mock) with vendor/bin/phpunit
# v10 — NOT the container's v11 system binary, which is Application-class
# incompatible — so a test failure still fails the push (it's `bash -e`;
# phpunit's non-zero exit aborts it) AND it emits the merged clover the gate
# reads. TEST_TMP lands that clover in the shared dndocker volume so the
# host-side gate can read it back. The gate then fails the push if ANY
# includes/ class dropped below 90% statement coverage.
#
# The configured container only exists in some local dev environments; anyone who
# clones this plugin standalone won't have it (nor the dndocker volume/tools),
# and the silent skip is the right behavior.
if [[ -n "$php_changed" ]]; then
	if ! command -v docker >/dev/null 2>&1 \
	   || ! docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${CONTAINER}$"; then
		step "$(dim "container ${CONTAINER} not available — skipping deploy + coverage")"
	else
		step "deploy → ${CONTAINER}"
		docker exec "$CONTAINER" "$DEPLOY_SCRIPT" >/dev/null || fail "deploy script failed"

		step "coverage suite in container (phpunit + clover)"
		out=/tmp/pre-push-coverage.out
		if docker exec -u bend -e TEST_TMP=/volumes/pyrobase/tmp "$CONTAINER" \
			"${TEST_DIR_IN_CONTAINER}/run-coverage.sh" >"$out" 2>&1; then
			cov_rc=0
		else
			cov_rc=$?
		fi
		tail -3 "$out" >&2
		[[ "$cov_rc" -ne 0 ]] && fail "coverage suite failed (exit ${cov_rc}) — full output at ${out}"
		ok "coverage suite clean"

		# Per-class 90% gate via the repo-local, self-contained scripts/coverage-gate.py.
		# run-coverage.sh writes the merged clover under $TEST_TMP/${COVERAGE_DIR}/;
		# skip gracefully off-dndocker or without python3.
		gate="$(git rev-parse --show-toplevel)/scripts/coverage-gate.py"
		dndocker_root="$(cd "$(git rev-parse --show-toplevel)/../../../.." 2>/dev/null && pwd || true)"
		clover="${dndocker_root}/volumes/pyrobase/tmp/${COVERAGE_DIR}/clover.xml"
		if [[ -f "$gate" && -f "$clover" ]] && command -v python3 >/dev/null 2>&1; then
			step "coverage gate (every class ≥ 90%)"
			python3 "$gate" "$clover" --threshold 90 >&2 \
				|| fail "coverage gate failed — a class is below 90% (see above)"
			ok "coverage gate passed"
		else
			step "$(dim 'coverage gate skipped (no clover / python3)')"
		fi
	fi
fi

ok "pre-push checks passed"
