# AI Newsletter — scored, durable digest pipeline.
#
#   github ┐
#   linear ┼─ ingest:partition                            (durable raw-item log)
#   feed   ┘
#   ingest:consumer ─ summarizer ─ scorer ─ scored:partition   (durable `scored` log)
#   scored:consumer ─ digest ─ digest:tee ─ digest:log
#
# The three connector sources (GitHub, Linear, RSS/Atom feeds) each emit normalized
# items on a `TICK` request (`request_node <source> TICK`). They append straight to the
# durable `ingest` partition (a fast write — no per-item LLM work on the source TICK, so
# the worker keeps heartbeating during a collect). A Consumer tails `ingest` one read-block
# per drain into the summarizer (one-line summary) → scorer (priority score) → the durable
# `scored` partition; spreading the blocking LLM enrich across drain cycles keeps the worker
# live. A second Consumer tails `scored` into the digest, and co-commits the digest's
# accumulated state (save_state) into its offsetlog via `set_snapshot_node digest` — so a
# respawned worker restores in lockstep with the cursor. Insights_CI reads that offsetlog
# snapshot to serve the dashboard. `void_warranty` lifts the partition's 4KB write cap (a
# raw item / scored batch can exceed PIPE_BUF); see ADR-4. The source DONE (TM_INFO) rides
# both partitions in order, so it reaches the digest after every item it precedes.
#
# Connectors emit nothing until configured via their :config verbs — set them in the
# topology console (set_vault_id renders a Vault-entry dropdown) or as `cmd <node>:config …`
# lines here. github needs set_vault_id + add_repo; linear set_vault_id; feed add_url;
# summarizer/digest take set_vault_id + add_profile (set_api_url/set_model/set_feature are
# optional — they default to the AI proxy / gpt-oss-120b / newspack-ai-newsletter). The
# digest composes + writes digest:log automatically once all sources report DONE for the
# cycle (the dashboard Collect RESETs then TICKs them).
var num_partitions = 1

make_node Github_Source  github
cmd github:config set_vault_id github
cmd github:config add_repo Automattic/newspack-ads
cmd github:config add_repo Automattic/newspack-activecampaign
cmd github:config add_repo Automattic/newspack-manager
cmd github:config add_repo Automattic/newspack-network
cmd github:config add_repo Automattic/newspack-plugin

make_node Linear_Source  linear
cmd linear:config set_vault_id linear

make_node Feed_Source    feed
cmd feed:config add_url https://make.wordpress.org/core/feed/
cmd feed:config add_url https://wordpress.org/news/feed/
cmd feed:config add_url https://automattic.com/blog/feed/

# ingest: raw fetched items buffer between the (bursty) sources and the LLM summarizer,
# so a TICK's fetch+write is fast and the per-item enrich is paced by the consumer.
make_node Partition      ingest:partition <config:logs_dir>/ingest.p<partition> <config:segment_size> <config:min_segments> <config:max_segments> <config:min_lifetime> <config:max_lifetime>
cmd ingest:partition:config void_warranty

make_node Consumer       ingest:consumer  <config:logs_dir>/ingest.p<partition> <config:offsets_dir>/ingest.p<partition> <config:deadletter_dir>/ingest.p<partition>
cmd ingest:consumer:config set_line_mode true

make_node Summarizer     summarizer
cmd summarizer:config set_api_url  https://public-api.wordpress.com/wpcom/v2/ai-api-proxy/v1
cmd summarizer:config set_vault_id AI-proxy
cmd summarizer:config set_model    gpt-oss-120b
cmd summarizer:config set_feature  newspack-ai-newsletter
cmd summarizer:config add_profile  Engineers building WordPress publishing tools for Newspack.
cmd summarizer:config add_profile  Prioritize shipped releases, merged PRs that change behavior or APIs, and runtime/infra changes or incidents.
cmd summarizer:config add_profile  Deprioritize dependency bumps, docs typos, and cosmetic tweaks.

make_node Scorer         scorer

make_node Partition      scored:partition <config:logs_dir>/scored.p<partition> <config:segment_size> <config:min_segments> <config:max_segments> <config:min_lifetime> <config:max_lifetime>
cmd scored:partition:config void_warranty

make_node Consumer       scored:consumer <config:logs_dir>/scored.p<partition> <config:offsets_dir>/scored.p<partition> <config:deadletter_dir>/scored.p<partition>
cmd scored:consumer:config set_snapshot_node digest
cmd scored:consumer:config set_line_mode true

# The digest auto-composes once every source has reported DONE. The sole arg is the
# progress denominator (done/total) — it MUST equal count(Insights_CI_Node::SOURCE_NODES).
make_node Digest_Builder digest scored:partition 3
cmd digest:config set_api_url  https://public-api.wordpress.com/wpcom/v2/ai-api-proxy/v1
cmd digest:config set_vault_id AI-proxy
cmd digest:config set_model    gpt-oss-120b
cmd digest:config set_feature  newspack-ai-newsletter
cmd digest:config add_profile  Engineers building WordPress publishing tools for Newspack.
cmd digest:config add_profile  Prioritize shipped releases, merged PRs that change behavior or APIs, and runtime/infra changes or incidents.
cmd digest:config add_profile  Deprioritize dependency bumps, docs typos, and cosmetic tweaks.
cmd digest:config add_profile  Do not produce tables.

make_node Tee            digest:tee

# digest:log path MUST match Digest_Builder_Node::DIGEST_PATH (Insights_CI reads the latest segment from there).
make_node Log            digest:log /tmp/newspack-ai-newsletter/digest.md 1 2 7 0 0
cmd digest:log:config void_warranty

connect_node github          ingest:partition
connect_node linear          ingest:partition
connect_node feed            ingest:partition
connect_node ingest:consumer summarizer
connect_node summarizer      scorer
connect_node scorer          scored:partition
connect_node scored:consumer digest
connect_node digest          digest:tee
connect_node digest:tee      digest:log
