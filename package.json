{
	"name": "newspack-ai-newsletter",
	"version": "0.2.13",
	"private": true,
	"description": "AI-driven team intelligence digest built on newspack-nodes.",
	"author": "Automattic",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"build": "npm run clean && node scripts/build.mjs",
		"watch": "npm run clean && node scripts/build.mjs --watch",
		"clean": "rm -rf build",
		"release:archive": "./build-release.sh",
		"fix:js": "eslint --fix --no-error-on-unmatched-pattern 'src/**/*.{js,jsx}' 'scripts/**/*.mjs'",
		"fix:php": "phpcbf",
		"fix:scss": "stylelint --customSyntax postcss-scss --fix 'src/**/*.scss'",
		"format": "prettier --write 'src/**/*.{js,jsx,scss,json}'",
		"format:js": "prettier --write 'src/**/*.{js,jsx}'",
		"lint:js": "eslint --no-error-on-unmatched-pattern 'src/**/*.{js,jsx}' 'scripts/**/*.mjs' && node scripts/lint-comment-length.mjs src scripts",
		"lint:php": "phpcs",
		"lint:phpstan": "vendor/bin/phpstan analyse --memory-limit=2G --no-progress",
		"lint:scss": "stylelint --customSyntax postcss-scss 'src/**/*.scss'",
		"make-pot": "wp i18n make-pot . languages/newspack-ai-newsletter.pot --domain=newspack-ai-newsletter --exclude=node_modules,build,vendor,tests,release",
		"test:js": "jest --passWithNoTests",
		"test:js:coverage": "jest --passWithNoTests --coverage --collectCoverageFrom='src/**/*.{js,jsx}' --coverageReporters=json-summary --coverageReporters=text"
	},
	"dependencies": {
		"@wordpress/api-fetch": "^7.0.0",
		"@wordpress/block-library": "^9.48.1",
		"@wordpress/blocks": "^15.21.1",
		"@wordpress/components": "^35.0.1",
		"@wordpress/element": "^6.0.0",
		"@wordpress/i18n": "^6.18.0",
		"@wordpress/icons": "^10.0.0",
		"@xyflow/react": "^12.0.0",
		"d3": "^7.8.5",
		"d3-flame-graph": "^4.1.3"
	},
	"devDependencies": {
		"@babel/preset-env": "^7.29.5",
		"@babel/preset-react": "^7.28.5",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^19.8.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.2",
		"@wordpress/eslint-plugin": "^24.5.0",
		"@wordpress/prettier-config": "^4.46.0",
		"@wordpress/stylelint-config": "^23.38.0",
		"babel-jest": "^30.4.1",
		"esbuild": "^0.28.0",
		"eslint": "^8.57.1",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "^30.4.1",
		"lint-staged": "^15.5.2",
		"postcss-scss": "^4.0.9",
		"prettier": "npm:wp-prettier@^3.0.3",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"rtlcss": "^4.3.0",
		"sass": "^1.99.0",
		"stylelint": "^16.26.1"
	},
	"lint-staged": {
		"*.{js,jsx}": [
			"eslint",
			"node scripts/lint-comment-length.mjs"
		],
		"*.scss": "stylelint --customSyntax postcss-scss",
		"*.php": [
			"phpcs",
			"sh -c 'npm run lint:phpstan --silent'",
			"php scripts/lint-comment-length.php"
		]
	},
	"browserslist": [
		"extends @wordpress/browserslist-config"
	],
	"overrides": {
		"@typescript-eslint/typescript-estree": {
			"minimatch": "^9.0.7"
		},
		"@babel/runtime": "^7.26.10",
		"@babel/core": "^7.29.6",
		"js-yaml": "^4.2.0"
	}
}
